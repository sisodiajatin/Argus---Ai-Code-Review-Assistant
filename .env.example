# GitHub App Configuration
GITHUB_APP_ID=your_github_app_id
GITHUB_PRIVATE_KEY_PATH=./private-key.pem
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# For cloud deployment (Render/Railway): paste PEM content instead of using a file
# GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"

# AI Provider Configuration (supports any OpenAI-compatible API)
# Recommended free option: Google Gemini — get a key at https://aistudio.google.com/apikey
AI_API_KEY=your_api_key_here
AI_MODEL=gemini-2.0-flash
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Other provider examples:
# Groq (free): AI_BASE_URL=https://api.groq.com/openai/v1  AI_MODEL=llama-3.3-70b-versatile
# DeepSeek:    AI_BASE_URL=https://api.deepseek.com         AI_MODEL=deepseek-chat
# OpenAI:     AI_BASE_URL=https://api.openai.com/v1         AI_MODEL=gpt-4

# Database (Docker uses /data/codereview.db automatically — no change needed)
DATABASE_URL=sqlite+aiosqlite:///./codereview.db

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info

# GitHub OAuth (optional — needed for dashboard login)
# GITHUB_CLIENT_ID=your_oauth_app_client_id
# GITHUB_CLIENT_SECRET=your_oauth_app_client_secret
